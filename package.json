{
  "name": "petjourney-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-frontend": "npm install --prefix frontend",
    "install-backend": "npm install --prefix backend",
    "postinstall": "npm run install-frontend && npm run install-backend",
    "build": "npm run build --prefix frontend",
    "dev": "npx -y concurrently -n BE,FE -c blue,green \"node backend/server.js\" \"npm run dev --prefix frontend\"",
    "dev:backend": "node backend/server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "seed": "node backend/seeder.js"
  },
  "dependencies": {
    "multer": "^2.1.1"
  }
}
